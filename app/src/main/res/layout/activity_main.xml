<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="#1565C0">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Custom Fake GPS"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tv_root_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Root Status: Checking..."
            android:textSize="12sp"
            android:textColor="#B3E5FC"
            android:gravity="center"/>

    </LinearLayout>

    <!-- Map View -->
    <org.osmdroid.views.MapView
        android:id="@+id/map_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Tap hint -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap peta untuk pilih lokasi"
        android:textSize="11sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:background="#1976D2"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"/>

    <!-- Bottom Panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="#F5F5F5">

        <!-- Coordinates Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Latitude"
                    android:textSize="11sp"
                    android:textColor="#757575"/>

                <EditText
                    android:id="@+id/edit_latitude"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="-6.2088"
                    android:inputType="numberDecimal|numberSigned"
                    android:textSize="14sp"
                    android:background="@android:drawable/editbox_background"
                    android:padding="6dp"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Longitude"
                    android:textSize="11sp"
                    android:textColor="#757575"/>

                <EditText
                    android:id="@+id/edit_longitude"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="106.8456"
                    android:inputType="numberDecimal|numberSigned"
                    android:textSize="14sp"
                    android:background="@android:drawable/editbox_background"
                    android:padding="6dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Action Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_set_location"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SET LOKASI"
                android:textColor="#FFFFFF"
                android:background="#4CAF50"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btn_stop_fake"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="STOP"
                android:textColor="#FFFFFF"
                android:background="#F44336"
                android:layout_marginStart="4dp"
                android:enabled="false"/>

        </LinearLayout>

        <!-- Status -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: IDLE"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"/>

    </LinearLayout>

</LinearLayout>
